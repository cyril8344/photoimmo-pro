{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" },
    { "source": "/gallery/:token*", "destination": "/index.html" },
    { "source": "/", "destination": "/landing.html" }
  ]
}
