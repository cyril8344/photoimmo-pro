# Supabase (https://supabase.com → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
# Clé service — JAMAIS exposée côté client, uniquement dans les fonctions serverless
SUPABASE_SERVICE_KEY=eyJhbGci...

# Google Drive API (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REFRESH_TOKEN=1//xxxx

# Resend email (https://resend.com)
# Vérifier votre domaine DNS dans Resend → Domains pour envoyer depuis votre propre adresse
RESEND_API_KEY=re_xxxx
# Adresse expéditeur une fois votre domaine vérifié (ex: hello@votredomaine.fr)
EMAIL_FROM=notifications@photoimmo.pro

# Stripe — MODE TEST (développement)
# Utiliser les clés sk_test_*** + price IDs de test
# STRIPE_SECRET_KEY=sk_test_xxxx
# STRIPE_PRICE_MONTHLY=price_test_xxxx
# STRIPE_PRICE_YEARLY=price_test_xxxx

# Stripe — MODE LIVE (production)
# Remplacer par les clés sk_live_*** du dashboard Stripe (onglet "Live")
# Créer 2 produits : "PhotoImmo Pro Mensuel" 29€/mois et "PhotoImmo Pro Annuel" 249€/an
# Copier les price_live_*** correspondants
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_MONTHLY=price_xxxx
STRIPE_PRICE_YEARLY=price_xxxx

# App URL (pour les redirections Stripe et les emails)
APP_URL=https://your-domain.fr

# Portfolio photographe
PORTFOLIO_BASE_URL=https://your-domain.fr

# Sécurité
SESSION_TIMEOUT_MINUTES=30
GALLERY_TOKEN_EXPIRY_DAYS=30
